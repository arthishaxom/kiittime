{
  "$schema": "https://turbo.build/schema.json",
  "ui":"tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "pyproject.toml", "uv.lock"],
      "outputs": ["dist/**", "build/**", ".next/**", "web-build/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"],
      "inputs": ["$TURBO_DEFAULT$", "pyproject.toml", "uv.lock"]
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "pyproject.toml", "uv.lock"]
    },
    "format": {
      "inputs": ["$TURBO_DEFAULT$", "pyproject.toml", "uv.lock"]
    }
  }
}
